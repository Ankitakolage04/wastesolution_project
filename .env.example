# MyWasteSolution Scraper & API Configuration
# Copy to .env and fill in your actual values

# ──────────────────────────────────────────────────────────────────────────
# MongoDB Configuration
# ──────────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
# OR for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

MONGO_DB_NAME=mywastesolution
MONGO_COLLECTION=profiles


# ──────────────────────────────────────────────────────────────────────────
# Scraper Configuration
# ──────────────────────────────────────────────────────────────────────────
BASE_URL=https://www.mywastesolution.com
MAX_PROFILES=50
CONCURRENT_PAGES=10
REQUEST_DELAY_MS=1000

# Output file for JSON backup
OUTPUT_JSON=profiles.json

# Enable Playwright debug mode (false for headless, true to watch browser)
HEADLESS=true


# ──────────────────────────────────────────────────────────────────────────
# LLM Configuration - API Keys
# ──────────────────────────────────────────────────────────────────────────

# Groq API (free tier: 30 req/min)
# Get key from: https://console.groq.com
GROQ_API_KEY=

# Google Gemini API (free tier: 60 req/min)
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude API (free tier: 5 req/min, limited tokens)
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=


# ──────────────────────────────────────────────────────────────────────────
# LLM Configuration - Behavior
# ──────────────────────────────────────────────────────────────────────────

# Which LLM to use first (groq, gemini, or claude)
# System will auto-fallback to next available if primary hits rate limit
PRIMARY_LLM=groq

# Enable/disable specific providers
LLM_ENABLE_GROQ=true
LLM_ENABLE_GEMINI=true
LLM_ENABLE_CLAUDE=true

# LLM call timeout in seconds
LLM_TIMEOUT=30

# Number of retries on failure
LLM_RETRIES=3

# Use LLM for structuring profiles (identify task, category, etc.)
GEMINI_ENABLED=true


# ──────────────────────────────────────────────────────────────────────────
# FastAPI Configuration
# ──────────────────────────────────────────────────────────────────────────
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT Secret for auth (if implementing authentication)
SECRET_KEY=your-secret-key-here-change-in-production
